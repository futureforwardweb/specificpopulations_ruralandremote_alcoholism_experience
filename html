function onComposeKey(e) { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendJake(); } }

function sendJake() {
  const inp = document.getElementById('tcinput');
  const msg = inp.value.trim();
  if (!msg) return;
  inp.value = ''; inp.style.height = 'auto';
  document.getElementById('tcsend').classList.remove('active');
  document.getElementById('tcompose').style.display = 'none';
  const now = '7:' + (25 + Math.floor(Math.random()*5)).toString().padStart(2,'0') + ' PM';
  addMsg('tmsgs', 'ttyp', { side:'out', text:msg, time:now }, () => {
    setTimeout(() => thommoRespond(detectSentiment(msg)), 500);
  });
}

function detectSentiment(msg) {
  const m = msg.toLowerCase();
  if (/piss off|leave me|none of your|mind your own|f.{0,2}k off|back off/i.test(m)) return 'angry';
  if (/not (really|great|good|okay|ok|fine)|pretty (rough|bad|shit)|struggling|tired|flat|heavy|stressed|haven.t been|can.t sleep|sort of|kind of|been rough|not sleeping|too much/i.test(m)) return 'honest';
  return 'deflect';
}

function thommoRespond(sentiment) {
  const t1 = '7:' + (28 + Math.floor(Math.random()*4)).toString().padStart(2,'0') + ' PM';
  const t2 = '7:' + (32 + Math.floor(Math.random()*3)).toString().padStart(2,'0') + ' PM';
  let msgs, note;
  if (sentiment === 'angry') {
    msgs = [{ side:'in', text:'Alright.', time:t1 }];
    setTimeout(() => addMsg('tmsgs','ttyp',{ side:'in', text:'I\'m here if you need. No pressure.', time:t2 }, showThommoNote), 2000);
    note = 'Even when Jake pushed back, Thommo didn\'t push harder. That\'s the move — stay available without demanding anything.';
  } else if (sentiment === 'honest') {
    msgs = [{ side:'in', text:'Yeah. That\'s what I thought.', time:t1 }];
    setTimeout(() => addMsg('tmsgs','ttyp',{ side:'in', text:'I\'m here mate. Don\'t have to talk about it — just wanted you to know.', time:t2 }, showThommoNote), 2000);
    note = 'Jake let himself be honest. Thommo didn\'t flinch. Something shifted — not fixed, just... known.';
  } else {
    msgs = [{ side:'in', text:'Jake.', time:t1 }];
    setTimeout(() => addMsg('tmsgs','ttyp',{ side:'in', text:'Come on. For real.', time:'7:29 PM' }, () => {
      setTimeout(() => addMsg('tmsgs','ttyp',{ side:'in', text:'I\'m here if things are rough. You know that.', time:t2 }, showThommoNote), 1800);
    }), 1500);
    note = 'Jake deflected. Thommo didn\'t drop it — he pushed once, gently. That one extra message is the whole skill.';
  }
  if (msgs) msgs.forEach(m => addMsg('tmsgs', 'ttyp', m, null));
  function showThommoNote() {
    const n = document.getElementById('thommo-note');
    n.textContent = note; n.style.display = 'block';
    setTimeout(() => n.classList.add('vis'), 50);
    setTimeout(() => document.getElementById('s8b').scrollIntoView({ behavior:'smooth' }), 3500);
  }
}

