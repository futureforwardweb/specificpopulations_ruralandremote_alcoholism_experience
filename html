// ── COUNTDOWN BAR SYSTEM ──
// Each bar has: barId (e.g. 'cb-s1'), targetId (e.g. 's2'), seconds
const cbState = {};

function startCountdown(barId, targetId, seconds) {
  const bar = document.getElementById(barId);
  if (!bar || cbState[barId]?.started) return;
  cbState[barId] = { started: true, interval: null, remaining: seconds };

  bar.classList.add('show');

  // Ring circumference = 2π×18 ≈ 113.1
  const circumference = 2 * Math.PI * 18;
  const fillEl = document.getElementById('crf-' + barId.replace('cb-',''));
  const numEl = document.getElementById('crn-' + barId.replace('cb-',''));

  // Set initial state
  if (fillEl) { fillEl.style.strokeDasharray = circumference; fillEl.style.strokeDashoffset = 0; }
  if (numEl) numEl.textContent = seconds;

  let elapsed = 0;
  const iv = setInterval(() => {
    elapsed++;
    const remaining = seconds - elapsed;
    const progress = elapsed / seconds;
    if (fillEl) fillEl.style.strokeDashoffset = circumference * progress;
    if (numEl) numEl.textContent = Math.max(0, remaining);
    if (elapsed >= seconds) {
      clearInterval(iv);
      document.getElementById(targetId)?.scrollIntoView({ behavior: 'smooth' });
    }
  }, 1000);
  cbState[barId].interval = iv;
}

function cbClick(targetId, barId) {
  if (cbState[barId]?.interval) clearInterval(cbState[barId].interval);
  document.getElementById(targetId)?.scrollIntoView({ behavior: 'smooth' });
}

// ── SECTION OBSERVERS ──
// barId, targetId, seconds, minVisibility
function watchSection(sectionId, barId, targetId, seconds) {
  let fired = false;
  const obs = new IntersectionObserver(es => {
    if (es[0].isIntersecting && !fired) {
      fired = true;
      startCountdown(barId, targetId, seconds);
    }
  }, { threshold: 0.55 });
  const el = document.getElementById(sectionId);
  if (el) obs.observe(el);
}

